{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/git-guard.sh\"",
            "timeout": 10,
            "statusMessage": "git-guard: checking for force-push / secret commits"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/edit-guard.sh\"",
            "timeout": 10,
            "statusMessage": "edit-guard: protecting migrations + Celery rules"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/lint-changed.sh\"",
            "timeout": 60,
            "statusMessage": "lint-changed: ruff on the edited file"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -d \"$D/.husky\" ] || { [ -d \"$D/.githooks\" ] && git -C \"$D\" config core.hooksPath .githooks 2>/dev/null; }; true",
            "timeout": 10,
            "statusMessage": "activating committed git hooks (core.hooksPath)"
          }
        ]
      }
    ]
  }
}
